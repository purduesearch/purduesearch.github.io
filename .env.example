# ── Slack App Credentials ─────────────────────────────────────
# Bot token (xoxb-...) — found under OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Signing secret — found under Basic Information
SLACK_SIGNING_SECRET=your-signing-secret

# App-level token (xapp-...) — required for Socket Mode
# Create one under Basic Information → App-Level Tokens with connections:write scope
SLACK_APP_TOKEN=xapp-your-app-token

# OAuth client credentials — found under Basic Information → App Credentials
SLACK_CLIENT_ID=your-client-id
SLACK_CLIENT_SECRET=your-client-secret

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://clubpm:clubpm_dev@localhost:5432/club_pm

# ── Session ───────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-random-string

# ── Frontend ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Server ────────────────────────────────────────────────────
PORT=3000
