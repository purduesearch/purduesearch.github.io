generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Models ───────────────────────────────────────────────────

model session {
  sid    String   @id @db.VarChar(258)
  sess   Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], map: "IDX_session_expire")
}

// ── Enums ────────────────────────────────────────────────────

enum Role {
  ADMIN
  LEAD
  MEMBER
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum ProjectType {
  ENGINEERING
  RESEARCH
  HYBRID
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ActivityType {
  TASK_CREATED
  TASK_UPDATED
  TASK_DELETED
  STATUS_CHANGED
  ASSIGNEE_CHANGED
  COMMENT_ADDED
  SUBTASK_ADDED
  DEPENDENCY_ADDED
  MILESTONE_CREATED
  MILESTONE_COMPLETED
  PROJECT_UPDATED
  RECURRING_SPAWNED
}

enum RecurringInterval {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum NotificationTargetType {
  CHANNEL
  DM
  GROUP_DM
}

enum TaskProgress {
  NO_PROGRESS
  IN_PROGRESS
  COMPLETED
}

enum MilestoneStatus {
  ON_TRACK
  AT_RISK
  BEHIND
  COMPLETED
  CANCELLED
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_COMPLETED
  TASK_UPDATED
  TASK_COMMENTED
  TASK_MENTIONED
  TASK_DUE_SOON
  TASK_OVERDUE
  MILESTONE_COMPLETED
  MILESTONE_AT_RISK
  PROJECT_UPDATE
  STANDUP_POSTED
  COMMENT_REPLY
  SYSTEM
}

// ── Models ───────────────────────────────────────────────────

model Member {
  id          String          @id @default(cuid())
  slackId     String          @unique
  slackHandle String
  displayName String
  avatarUrl   String?
  title       String?
  email       String?
  timezone    String?
  team        String?
  bio         String?
  role            Role            @default(MEMBER)
  isAdmin         Boolean         @default(false)
  isBot           Boolean         @default(false)
  kanbanColumnOrder String[]      @default(["TODO", "IN_PROGRESS", "BLOCKED", "DONE"])
  notificationPrefs String[]      @default(["daily_reminders", "weekly_digest", "project_updates"])
  notificationChannels  Json?
  quietHoursStart       Int?
  quietHoursEnd         Int?
  mutedProjectIds       String[]  @default([])
  tasks           Task[]          @relation("TaskAssignees")
  projects        ProjectMember[]
  comments        TaskComment[]
  activities      Activity[]
  notifications         Notification[] @relation("NotificationRecipient")
  sentNotifications     Notification[] @relation("NotificationActor")
  activityLogs    ActivityLog[]
  ownedMilestones Milestone[]     @relation("MilestoneOwner")
  timeLogs        TimeLog[]
  updates         ProjectUpdate[]
  organizedEvents Event[]         @relation("EventOrganizer")
  attendedEvents  Event[]         @relation("EventAttendees")
  submissions     OutreachSubmission[] @relation("SubmissionAuthor")
  reviewedSubmissions OutreachSubmission[] @relation("SubmissionReviewer")
  outreachComments OutreachComment[] @relation("OutreachCommentAuthor")
  createdAt       DateTime        @default(now())
}

model Project {
  id               String          @id @default(cuid())
  name             String
  description      String?
  driveLink        String?
  slackChannel     String?
  slackChannelId   String?
  slackChannelName String?
  status           ProjectStatus   @default(ACTIVE)
  type         ProjectType
  startDate    DateTime?
  targetDate   DateTime?
  tags                 Tag[]
  members              ProjectMember[]
  tasks                Task[]
  milestones           Milestone[]
  updates              ProjectUpdate[]
  activities           Activity[]
  activityLogs         ActivityLog[]
  notificationTargets  ProjectNotificationTarget[]
  notifications        Notification[]
  events               Event[]
  submissions          OutreachSubmission[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
}

model ProjectMember {
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId    String
  projectRole String   @default("Contributor")
  joinedAt    DateTime @default(now())

  @@id([projectId, memberId])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  assignees   Member[]   @relation("TaskAssignees")
  slackMsgTs  String?
  tags        Tag[]        @relation("TaskTags")
  attachments String[]
  comments    TaskComment[]

  // ── Subtask hierarchy ──
  parentTask   Task?    @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  parentTaskId String?
  subtasks     Task[]   @relation("TaskSubtasks")

  // ── Dependencies ──
  blockedBy    TaskDependency[] @relation("TaskDependencies_blocked")
  blocks       TaskDependency[] @relation("TaskDependencies_blocking")

  // ── Progress ──
  progress     TaskProgress @default(NO_PROGRESS)

  // ── Time tracking ──
  estimatedHours Float?
  storyPoints    Int?
  timeLogs       TimeLog[]

  // ── Recurring ──
  recurringInterval  RecurringInterval?
  lastSpawnedAt      DateTime?
  escalatedAt        DateTime?
  sourceTaskId       String?
  isRecurring        Boolean   @default(false)
  recurrencePattern  String?
  recurrenceEndDate  DateTime?
  recurringParentId  String?

  // ── Milestone ──
  milestone    Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  milestoneId  String?

  // ── Events ──
  priorityEvents Event[] @relation("EventPriorityTasks")

  activityLogs ActivityLog[]
  notifications Notification[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([parentTaskId])
  @@index([milestoneId])
}

model TaskComment {
  id        String      @id @default(cuid())
  content   String
  task      Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  author    Member      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  parentId  String?
  parent    TaskComment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies   TaskComment[] @relation("CommentThread")
  editedAt  DateTime?
  reactions Json?
  createdAt DateTime    @default(now())

  @@index([taskId])
  @@index([authorId])
  @@index([parentId])
}

model Milestone {
  id          String          @id @default(cuid())
  title       String
  dueDate     DateTime?
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  tasks       Task[]
  status      MilestoneStatus @default(ON_TRACK)
  description String?
  ownerId     String?
  owner       Member?         @relation("MilestoneOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  completedAt DateTime?
  slackMsgTs  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([projectId, dueDate])
}

model Activity {
  id         String       @id @default(cuid())
  type       ActivityType
  entityId   String
  entityType String       // "Task", "Project", "Milestone"
  project    Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  String?
  member     Member?      @relation(fields: [memberId], references: [id], onDelete: SetNull)
  memberId   String?
  metadata   Json?
  createdAt  DateTime     @default(now())

  @@index([projectId])
  @@index([entityId])
  @@index([createdAt])
}

model ProjectUpdate {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  authorId  String?
  author    Member?  @relation(fields: [authorId], references: [id], onDelete: SetNull)
  content   String
  postedAt  DateTime @default(now())

  @@index([projectId])
}

// ── Activity Audit Log ───────────────────────────────────────
// Payload shapes by eventType:
//   TASK_CREATED         { taskTitle, priority, assigneeNames[] }
//   TASK_UPDATED         { taskTitle, changes[{ field, from, to }] }
//   TASK_COMPLETED       { taskTitle }
//   TASK_DELETED         { taskTitle }
//   TASK_ASSIGNED        { taskTitle, assigneeNames[] }
//   TASK_REASSIGNED      { taskTitle, fromName, toName }
//   TASK_SNOOZED         { taskTitle, newDueDate }
//   TASK_NOTE_ADDED      { taskTitle, preview }
//   TASK_SUBTASK_CREATED { parentTitle, subtaskTitle }
//   PROJECT_CREATED      { projectName }
//   PROJECT_UPDATED      { changes[{ field, from, to }] }
//   PROJECT_MEMBER_ADDED { memberName, role }
//   STANDUP_POSTED       { preview }

enum ActivitySource {
  WEB
  SLACK
}

enum ActivityEventType {
  TASK_CREATED
  TASK_UPDATED
  TASK_COMPLETED
  TASK_DELETED
  TASK_ASSIGNED
  TASK_REASSIGNED
  TASK_SNOOZED
  TASK_NOTE_ADDED
  TASK_SUBTASK_CREATED
  PROJECT_CREATED
  PROJECT_UPDATED
  PROJECT_MEMBER_ADDED
  STANDUP_POSTED
}

model ActivityLog {
  id        String            @id @default(cuid())
  projectId String
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId    String?
  task      Task?             @relation(fields: [taskId], references: [id], onDelete: SetNull)
  memberId  String?
  member    Member?           @relation(fields: [memberId], references: [id], onDelete: SetNull)
  source    ActivitySource
  eventType ActivityEventType
  payload   Json
  createdAt DateTime          @default(now())

  @@index([projectId, createdAt(sort: Desc)])
  @@index([taskId])
}

model ProjectNotificationTarget {
  id             String                 @id @default(cuid())
  project        Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId      String
  type           NotificationTargetType @default(CHANNEL)
  slackChannelId String
  eventTypes     String[]               @default([])
  createdAt      DateTime               @default(now())

  @@unique([projectId, slackChannelId])
  @@index([projectId])
  @@index([slackChannelId])
}

model Tag {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6c5ce7")
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     Task[]   @relation("TaskTags")
  createdAt DateTime @default(now())

  @@unique([name, projectId])
  @@index([projectId])
}

model TaskDependency {
  blockingTaskId String
  blockedTaskId  String
  blockingTask   Task   @relation("TaskDependencies_blocking", fields: [blockingTaskId], references: [id], onDelete: Cascade)
  blockedTask    Task   @relation("TaskDependencies_blocked",  fields: [blockedTaskId],  references: [id], onDelete: Cascade)

  @@id([blockingTaskId, blockedTaskId])
}

model Notification {
  id          String           @id @default(cuid())
  type        NotificationType
  recipientId String
  recipient   Member           @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actorId     String?
  actor       Member?          @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  projectId   String?
  project     Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId      String?
  task        Task?            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  commentId   String?
  message     String
  read        Boolean          @default(false)
  readAt      DateTime?
  metadata    Json?
  createdAt   DateTime         @default(now())

  @@index([recipientId, read, createdAt(sort: Desc)])
  @@index([recipientId, createdAt(sort: Desc)])
  @@index([projectId])
}

model TimeLog {
  id       String   @id @default(cuid())
  taskId   String
  memberId String
  minutes  Int
  note     String?
  loggedAt DateTime @default(now())
  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  member   Member   @relation(fields: [memberId], references: [id])

  @@index([taskId])
  @@index([memberId])
}

// ── Events ───────────────────────────────────────────────────

enum EventType {
  MEETING
  DEADLINE
  WORKSHOP
  SOCIAL
  OTHER
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String?
  type        EventType @default(MEETING)
  startTime   DateTime
  endTime     DateTime?
  location    String?
  isVirtual   Boolean   @default(false)

  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId   String?

  priorityTasks Task[]  @relation("EventPriorityTasks")

  organizer   Member?   @relation("EventOrganizer", fields: [organizerId], references: [id], onDelete: SetNull)
  organizerId String?

  attendees   Member[]  @relation("EventAttendees")

  notes       String?

  isRecurring       Boolean   @default(false)
  recurrencePattern String?
  recurrenceEndDate DateTime?

  submissions OutreachSubmission[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([startTime])
  @@index([projectId])
  @@index([organizerId])
}

// ── Outreach ─────────────────────────────────────────────────

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  APPROVED
  PUBLISHED
  REJECTED
}

enum SubmissionType {
  SOCIAL_POST
  NEWSLETTER
  PHOTO
  VIDEO
  ANNOUNCEMENT
  EVENT_PROMO
}

model OutreachSubmission {
  id          String           @id @default(cuid())
  title       String
  type        SubmissionType
  status      SubmissionStatus @default(DRAFT)
  content     String?
  mediaUrls   String[]
  platform    String[]

  project     Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId   String?

  event       Event?           @relation(fields: [eventId], references: [id], onDelete: SetNull)
  eventId     String?

  author      Member           @relation("SubmissionAuthor", fields: [authorId], references: [id])
  authorId    String

  reviewer    Member?          @relation("SubmissionReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  reviewerId  String?

  reviewNote  String?
  scheduledAt DateTime?
  publishedAt DateTime?

  comments    OutreachComment[]

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([status])
  @@index([authorId])
  @@index([projectId])
}

model OutreachComment {
  id           String   @id @default(cuid())
  submissionId String
  submission   OutreachSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  authorId     String
  author       Member   @relation("OutreachCommentAuthor", fields: [authorId], references: [id])
  body         String
  mentions     String[]
  parentId     String?
  parent       OutreachComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies      OutreachComment[] @relation("CommentReplies")
  createdAt    DateTime @default(now())

  @@index([submissionId])
}

model HashtagStat {
  id          String    @id @default(cuid())
  tag         String    @unique
  category    String?
  useCount    Int       @default(0)
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

