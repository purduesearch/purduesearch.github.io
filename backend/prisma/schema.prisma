generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Models ───────────────────────────────────────────────────

model session {
  sid    String   @id @db.VarChar(258)
  sess   Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], map: "IDX_session_expire")
}

// ── Enums ────────────────────────────────────────────────────

enum Role {
  ADMIN
  LEAD
  MEMBER
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum ProjectType {
  ENGINEERING
  RESEARCH
  HYBRID
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ActivityType {
  TASK_CREATED
  TASK_UPDATED
  TASK_DELETED
  STATUS_CHANGED
  ASSIGNEE_CHANGED
  COMMENT_ADDED
  SUBTASK_ADDED
  DEPENDENCY_ADDED
  MILESTONE_CREATED
  MILESTONE_COMPLETED
  PROJECT_UPDATED
  RECURRING_SPAWNED
}

enum RecurringInterval {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum NotificationTargetType {
  CHANNEL
  DM
  GROUP_DM
}

enum TaskProgress {
  NO_PROGRESS
  IN_PROGRESS
  COMPLETED
}

enum MilestoneStatus {
  ON_TRACK
  AT_RISK
  BEHIND
  COMPLETED
  CANCELLED
}

// ── Models ───────────────────────────────────────────────────

model Member {
  id          String          @id @default(cuid())
  slackId     String          @unique
  slackHandle String
  displayName String
  avatarUrl   String?
  role            Role            @default(MEMBER)
  kanbanColumnOrder String[]      @default(["TODO", "IN_PROGRESS", "BLOCKED", "DONE"])
  notificationPrefs String[]      @default(["daily_reminders", "weekly_digest", "project_updates"])
  tasks           Task[]          @relation("TaskAssignees")
  projects        ProjectMember[]
  comments        TaskComment[]
  activities      Activity[]
  activityLogs    ActivityLog[]
  ownedMilestones Milestone[]     @relation("MilestoneOwner")
  createdAt       DateTime        @default(now())
}

model Project {
  id               String          @id @default(cuid())
  name             String
  description      String?
  driveLink        String?
  slackChannel     String?
  slackChannelId   String?
  slackChannelName String?
  status           ProjectStatus   @default(ACTIVE)
  type         ProjectType
  startDate    DateTime?
  targetDate   DateTime?
  tags                 String[]
  members              ProjectMember[]
  tasks                Task[]
  milestones           Milestone[]
  updates              ProjectUpdate[]
  activities           Activity[]
  activityLogs         ActivityLog[]
  notificationTargets  ProjectNotificationTarget[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
}

model ProjectMember {
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId    String
  projectRole String   @default("Contributor")
  joinedAt    DateTime @default(now())

  @@id([projectId, memberId])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  assignees   Member[]   @relation("TaskAssignees")
  slackMsgTs  String?
  tags        String[]
  attachments String[]
  comments    TaskComment[]

  // ── Subtask hierarchy ──
  parentTask   Task?    @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  parentTaskId String?
  subtasks     Task[]   @relation("TaskSubtasks")

  // ── Dependencies ──
  blockedBy    Task[]   @relation("TaskDependencies")
  blocking     Task[]   @relation("TaskDependencies")

  // ── Progress ──
  progress     TaskProgress @default(NO_PROGRESS)

  // ── Recurring ──
  recurringInterval RecurringInterval?
  lastSpawnedAt     DateTime?
  escalatedAt       DateTime?
  sourceTaskId      String?

  // ── Milestone ──
  milestone    Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  milestoneId  String?

  activityLogs ActivityLog[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([parentTaskId])
  @@index([milestoneId])
}

model TaskComment {
  id        String   @id @default(cuid())
  content   String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  author    Member   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([authorId])
}

model Milestone {
  id          String          @id @default(cuid())
  title       String
  dueDate     DateTime?
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  tasks       Task[]
  status      MilestoneStatus @default(ON_TRACK)
  description String?
  ownerId     String?
  owner       Member?         @relation("MilestoneOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  completedAt DateTime?
  slackMsgTs  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([projectId, dueDate])
}

model Activity {
  id         String       @id @default(cuid())
  type       ActivityType
  entityId   String
  entityType String       // "Task", "Project", "Milestone"
  project    Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  String?
  member     Member?      @relation(fields: [memberId], references: [id], onDelete: SetNull)
  memberId   String?
  metadata   Json?
  createdAt  DateTime     @default(now())

  @@index([projectId])
  @@index([entityId])
  @@index([createdAt])
}

model ProjectUpdate {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  authorId  String
  content   String
  postedAt  DateTime @default(now())

  @@index([projectId])
}

// ── Activity Audit Log ───────────────────────────────────────
// Payload shapes by eventType:
//   TASK_CREATED         { taskTitle, priority, assigneeNames[] }
//   TASK_UPDATED         { taskTitle, changes[{ field, from, to }] }
//   TASK_COMPLETED       { taskTitle }
//   TASK_DELETED         { taskTitle }
//   TASK_ASSIGNED        { taskTitle, assigneeNames[] }
//   TASK_REASSIGNED      { taskTitle, fromName, toName }
//   TASK_SNOOZED         { taskTitle, newDueDate }
//   TASK_NOTE_ADDED      { taskTitle, preview }
//   TASK_SUBTASK_CREATED { parentTitle, subtaskTitle }
//   PROJECT_CREATED      { projectName }
//   PROJECT_UPDATED      { changes[{ field, from, to }] }
//   PROJECT_MEMBER_ADDED { memberName, role }
//   STANDUP_POSTED       { preview }

enum ActivitySource {
  WEB
  SLACK
}

enum ActivityEventType {
  TASK_CREATED
  TASK_UPDATED
  TASK_COMPLETED
  TASK_DELETED
  TASK_ASSIGNED
  TASK_REASSIGNED
  TASK_SNOOZED
  TASK_NOTE_ADDED
  TASK_SUBTASK_CREATED
  PROJECT_CREATED
  PROJECT_UPDATED
  PROJECT_MEMBER_ADDED
  STANDUP_POSTED
}

model ActivityLog {
  id        String            @id @default(cuid())
  projectId String
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId    String?
  task      Task?             @relation(fields: [taskId], references: [id], onDelete: SetNull)
  memberId  String?
  member    Member?           @relation(fields: [memberId], references: [id], onDelete: SetNull)
  source    ActivitySource
  eventType ActivityEventType
  payload   Json
  createdAt DateTime          @default(now())

  @@index([projectId, createdAt(sort: Desc)])
  @@index([taskId])
}

model ProjectNotificationTarget {
  id             String                 @id @default(cuid())
  project        Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId      String
  type           NotificationTargetType @default(CHANNEL)
  slackChannelId String
  eventTypes     String[]               @default([])
  createdAt      DateTime               @default(now())

  @@unique([projectId, slackChannelId])
  @@index([projectId])
  @@index([slackChannelId])
}

