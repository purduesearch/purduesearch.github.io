generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Models ───────────────────────────────────────────────────

model session {
  sid    String   @id @db.VarChar(258)
  sess   Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], map: "IDX_session_expire")
}

// ── Enums ────────────────────────────────────────────────────

enum Role {
  ADMIN
  LEAD
  MEMBER
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum ProjectType {
  ENGINEERING
  RESEARCH
  HYBRID
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ActivityType {
  TASK_CREATED
  TASK_UPDATED
  TASK_DELETED
  STATUS_CHANGED
  ASSIGNEE_CHANGED
  COMMENT_ADDED
  SUBTASK_ADDED
  DEPENDENCY_ADDED
  MILESTONE_CREATED
  MILESTONE_COMPLETED
  PROJECT_UPDATED
  RECURRING_SPAWNED
}

enum RecurringInterval {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum NotificationTargetType {
  CHANNEL
  DM
  GROUP_DM
}

enum TaskProgress {
  NO_PROGRESS
  IN_PROGRESS
  COMPLETED
}

enum MilestoneStatus {
  ON_TRACK
  AT_RISK
  BEHIND
  COMPLETED
  CANCELLED
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_COMPLETED
  TASK_UPDATED
  TASK_COMMENTED
  TASK_MENTIONED
  TASK_DUE_SOON
  TASK_OVERDUE
  MILESTONE_COMPLETED
  MILESTONE_AT_RISK
  PROJECT_UPDATE
  STANDUP_POSTED
  COMMENT_REPLY
  SYSTEM
}

// ── Models ───────────────────────────────────────────────────

model Member {
  id          String          @id @default(cuid())
  slackId     String          @unique
  slackHandle String
  displayName String
  avatarUrl   String?
  title       String?
  email       String?
  timezone    String?
  team        String?
  bio         String?
  role            Role            @default(MEMBER)
  isAdmin         Boolean         @default(false)
  isBot           Boolean         @default(false)
  kanbanColumnOrder String[]      @default(["TODO", "IN_PROGRESS", "BLOCKED", "DONE"])
  notificationPrefs String[]      @default(["daily_reminders", "weekly_digest", "project_updates"])
  notificationChannels  Json?
  quietHoursStart       Int?
  quietHoursEnd         Int?
  mutedProjectIds       String[]  @default([])
  tasks           Task[]          @relation("TaskAssignees")
  projects        ProjectMember[]
  comments        TaskComment[]
  activities      Activity[]
  notifications         Notification[] @relation("NotificationRecipient")
  sentNotifications     Notification[] @relation("NotificationActor")
  activityLogs    ActivityLog[]
  ownedMilestones Milestone[]     @relation("MilestoneOwner")
  timeLogs        TimeLog[]
  updates         ProjectUpdate[]
  organizedEvents Event[]         @relation("EventOrganizer")
  attendedEvents  Event[]         @relation("EventAttendees")
  submissions     OutreachSubmission[] @relation("SubmissionAuthor")
  reviewedSubmissions OutreachSubmission[] @relation("SubmissionReviewer")
  outreachComments OutreachComment[] @relation("OutreachCommentAuthor")
  assets          OutreachAsset[]  @relation("AssetUploader")
  campaignsOwned  Campaign[]       @relation("CampaignOwner")
  ownedContacts   OutreachContact[] @relation("ContactOwner")
  contactInteractions ContactInteraction[]
  recordedMetrics PostMetric[]
  ownedRecurringTemplates RecurringTemplate[] @relation("RecurringTemplateOwner")
  submissionApprovals ApprovalRecord[] @relation("SubmissionApprover")
  createdAt       DateTime        @default(now())
}

model Project {
  id               String          @id @default(cuid())
  name             String
  description      String?
  driveLink        String?
  slackChannel     String?
  slackChannelId   String?
  slackChannelName String?
  status           ProjectStatus   @default(ACTIVE)
  type         ProjectType
  startDate    DateTime?
  targetDate   DateTime?
  programTag       String?         // "astrousa" | "sa2tp" | "research" | "software" | "business" (for public archive grouping)
  pressKitToken    String?         @unique
  tags                 Tag[]
  members              ProjectMember[]
  tasks                Task[]
  milestones           Milestone[]
  updates              ProjectUpdate[]
  activities           Activity[]
  activityLogs         ActivityLog[]
  notificationTargets  ProjectNotificationTarget[]
  notifications        Notification[]
  events               Event[]
  submissions          OutreachSubmission[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
}

model ProjectMember {
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId    String
  projectRole String   @default("Contributor")
  joinedAt    DateTime @default(now())

  @@id([projectId, memberId])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  assignees   Member[]   @relation("TaskAssignees")
  slackMsgTs  String?
  tags        Tag[]        @relation("TaskTags")
  attachments String[]
  comments    TaskComment[]

  // ── Subtask hierarchy ──
  parentTask   Task?    @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  parentTaskId String?
  subtasks     Task[]   @relation("TaskSubtasks")

  // ── Dependencies ──
  blockedBy    TaskDependency[] @relation("TaskDependencies_blocked")
  blocks       TaskDependency[] @relation("TaskDependencies_blocking")

  // ── Progress ──
  progress     TaskProgress @default(NO_PROGRESS)

  // ── Time tracking ──
  estimatedHours Float?
  storyPoints    Int?
  timeLogs       TimeLog[]

  // ── Recurring ──
  recurringInterval  RecurringInterval?
  lastSpawnedAt      DateTime?
  escalatedAt        DateTime?
  sourceTaskId       String?
  isRecurring        Boolean   @default(false)
  recurrencePattern  String?
  recurrenceEndDate  DateTime?
  recurringParentId  String?

  // ── Milestone ──
  milestone    Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  milestoneId  String?

  // ── Events ──
  priorityEvents Event[] @relation("EventPriorityTasks")

  activityLogs ActivityLog[]
  notifications Notification[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([parentTaskId])
  @@index([milestoneId])
}

model TaskComment {
  id        String      @id @default(cuid())
  content   String
  task      Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  author    Member      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  parentId  String?
  parent    TaskComment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies   TaskComment[] @relation("CommentThread")
  editedAt  DateTime?
  reactions Json?
  createdAt DateTime    @default(now())

  @@index([taskId])
  @@index([authorId])
  @@index([parentId])
}

model Milestone {
  id          String          @id @default(cuid())
  title       String
  dueDate     DateTime?
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  tasks       Task[]
  status      MilestoneStatus @default(ON_TRACK)
  description String?
  ownerId     String?
  owner       Member?         @relation("MilestoneOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  completedAt DateTime?
  slackMsgTs  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([projectId, dueDate])
}

model Activity {
  id         String       @id @default(cuid())
  type       ActivityType
  entityId   String
  entityType String       // "Task", "Project", "Milestone"
  project    Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  String?
  member     Member?      @relation(fields: [memberId], references: [id], onDelete: SetNull)
  memberId   String?
  metadata   Json?
  createdAt  DateTime     @default(now())

  @@index([projectId])
  @@index([entityId])
  @@index([createdAt])
}

model ProjectUpdate {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  authorId  String?
  author    Member?  @relation(fields: [authorId], references: [id], onDelete: SetNull)
  content   String
  postedAt  DateTime @default(now())

  @@index([projectId])
}

// ── Activity Audit Log ───────────────────────────────────────
// Payload shapes by eventType:
//   TASK_CREATED         { taskTitle, priority, assigneeNames[] }
//   TASK_UPDATED         { taskTitle, changes[{ field, from, to }] }
//   TASK_COMPLETED       { taskTitle }
//   TASK_DELETED         { taskTitle }
//   TASK_ASSIGNED        { taskTitle, assigneeNames[] }
//   TASK_REASSIGNED      { taskTitle, fromName, toName }
//   TASK_SNOOZED         { taskTitle, newDueDate }
//   TASK_NOTE_ADDED      { taskTitle, preview }
//   TASK_SUBTASK_CREATED { parentTitle, subtaskTitle }
//   PROJECT_CREATED      { projectName }
//   PROJECT_UPDATED      { changes[{ field, from, to }] }
//   PROJECT_MEMBER_ADDED { memberName, role }
//   STANDUP_POSTED       { preview }

enum ActivitySource {
  WEB
  SLACK
}

enum ActivityEventType {
  TASK_CREATED
  TASK_UPDATED
  TASK_COMPLETED
  TASK_DELETED
  TASK_ASSIGNED
  TASK_REASSIGNED
  TASK_SNOOZED
  TASK_NOTE_ADDED
  TASK_SUBTASK_CREATED
  PROJECT_CREATED
  PROJECT_UPDATED
  PROJECT_MEMBER_ADDED
  STANDUP_POSTED
}

model ActivityLog {
  id        String            @id @default(cuid())
  projectId String
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId    String?
  task      Task?             @relation(fields: [taskId], references: [id], onDelete: SetNull)
  memberId  String?
  member    Member?           @relation(fields: [memberId], references: [id], onDelete: SetNull)
  source    ActivitySource
  eventType ActivityEventType
  payload   Json
  createdAt DateTime          @default(now())

  @@index([projectId, createdAt(sort: Desc)])
  @@index([taskId])
}

model ProjectNotificationTarget {
  id             String                 @id @default(cuid())
  project        Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId      String
  type           NotificationTargetType @default(CHANNEL)
  slackChannelId String
  eventTypes     String[]               @default([])
  createdAt      DateTime               @default(now())

  @@unique([projectId, slackChannelId])
  @@index([projectId])
  @@index([slackChannelId])
}

model Tag {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6c5ce7")
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     Task[]   @relation("TaskTags")
  createdAt DateTime @default(now())

  @@unique([name, projectId])
  @@index([projectId])
}

model TaskDependency {
  blockingTaskId String
  blockedTaskId  String
  blockingTask   Task   @relation("TaskDependencies_blocking", fields: [blockingTaskId], references: [id], onDelete: Cascade)
  blockedTask    Task   @relation("TaskDependencies_blocked",  fields: [blockedTaskId],  references: [id], onDelete: Cascade)

  @@id([blockingTaskId, blockedTaskId])
}

model Notification {
  id          String           @id @default(cuid())
  type        NotificationType
  recipientId String
  recipient   Member           @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actorId     String?
  actor       Member?          @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  projectId   String?
  project     Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId      String?
  task        Task?            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  commentId   String?
  message     String
  read        Boolean          @default(false)
  readAt      DateTime?
  metadata    Json?
  createdAt   DateTime         @default(now())

  @@index([recipientId, read, createdAt(sort: Desc)])
  @@index([recipientId, createdAt(sort: Desc)])
  @@index([projectId])
}

model TimeLog {
  id       String   @id @default(cuid())
  taskId   String
  memberId String
  minutes  Int
  note     String?
  loggedAt DateTime @default(now())
  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  member   Member   @relation(fields: [memberId], references: [id])

  @@index([taskId])
  @@index([memberId])
}

// ── Events ───────────────────────────────────────────────────

enum EventType {
  MEETING
  DEADLINE
  WORKSHOP
  SOCIAL
  OTHER
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String?
  type        EventType @default(MEETING)
  startTime   DateTime
  endTime     DateTime?
  location    String?
  isVirtual   Boolean   @default(false)

  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId   String?

  priorityTasks Task[]  @relation("EventPriorityTasks")

  organizer   Member?   @relation("EventOrganizer", fields: [organizerId], references: [id], onDelete: SetNull)
  organizerId String?

  attendees   Member[]  @relation("EventAttendees")

  notes       String?

  isRecurring       Boolean   @default(false)
  recurrencePattern String?
  recurrenceEndDate DateTime?

  submissions OutreachSubmission[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([startTime])
  @@index([projectId])
  @@index([organizerId])
}

// ── Outreach ─────────────────────────────────────────────────

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  APPROVED
  PUBLISHED
  REJECTED
}

enum SubmissionType {
  SOCIAL_POST
  NEWSLETTER
  PHOTO
  VIDEO
  ANNOUNCEMENT
  EVENT_PROMO
}

model OutreachSubmission {
  id          String           @id @default(cuid())
  title       String
  type        SubmissionType
  status      SubmissionStatus @default(DRAFT)
  content     String?
  mediaUrls   String[]
  platform    String[]

  project     Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId   String?

  event       Event?           @relation(fields: [eventId], references: [id], onDelete: SetNull)
  eventId     String?

  author      Member           @relation("SubmissionAuthor", fields: [authorId], references: [id])
  authorId    String

  reviewer    Member?          @relation("SubmissionReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  reviewerId  String?

  reviewNote       String?
  scheduledAt      DateTime?
  publishedAt      DateTime?
  platformContent  Json?    // per-platform variants: { instagram: { caption, hashtags[], altText }, linkedin: { caption }, twitter: { caption }, ... }
  isTemplate       Boolean  @default(false)
  placeholders     Json?    // [{ key: "memberName", description: "Who to feature" }]
  safetyReport     Json?    // { safe: bool, issues: [{ category, severity, message, suggestedFix? }] }
  safetyCheckedAt  DateTime?
  newsletterHtml   String?  // Rich HTML for NEWSLETTER-type submissions

  campaign    Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  campaignId  String?

  comments    OutreachComment[]
  utmLinks    UtmLink[]
  metrics     PostMetric[]
  recurrences RecurringTemplate[]
  approvals   ApprovalRecord[]
  newsletterSends NewsletterSend[]

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([status])
  @@index([authorId])
  @@index([projectId])
  @@index([campaignId])
}

model OutreachComment {
  id           String   @id @default(cuid())
  submissionId String
  submission   OutreachSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  authorId     String
  author       Member   @relation("OutreachCommentAuthor", fields: [authorId], references: [id])
  body         String
  mentions     String[]
  parentId     String?
  parent       OutreachComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies      OutreachComment[] @relation("CommentReplies")
  createdAt    DateTime @default(now())

  @@index([submissionId])
}

model HashtagStat {
  id          String    @id @default(cuid())
  tag         String    @unique
  category    String?
  useCount    Int       @default(0)
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model BrandVoice {
  id          String   @id @default(cuid())
  name        String
  description String
  examples    String[]
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OutreachAsset {
  id           String   @id @default(cuid())
  name         String
  kind         String   // "IMAGE" | "VIDEO" | "GRAPHIC" | "LOGO" | "DOC"
  url          String
  driveFileId  String?
  thumbnailUrl String?
  altText      String?
  tags         String[]
  uploadedById String
  uploadedBy   Member   @relation("AssetUploader", fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([uploadedById])
}

model Campaign {
  id                String   @id @default(cuid())
  name              String
  description       String?
  startDate         DateTime
  endDate           DateTime?
  goalType          String?  // "RECRUITMENT" | "SPONSORSHIP" | "EVENT" | "AWARENESS"
  goalTarget        Int?
  goalProgress      Int      @default(0)
  color             String?  // hex for calendar/board chip
  ownerId           String
  owner             Member   @relation("CampaignOwner", fields: [ownerId], references: [id])
  requiredApprovers String[] @default([])  // member IDs who must approve before APPROVED status
  slug              String?  @unique
  isPublic          Boolean  @default(false)
  submissions       OutreachSubmission[]
  contacts          OutreachContact[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([ownerId])
}

model OutreachContact {
  id              String    @id @default(cuid())
  name            String
  email           String?
  phone           String?
  organization    String?
  role            String?
  contactType     String    // "SPONSOR" | "PRESS" | "PARTNER" | "PROSPECT" | "ALUMNI"
  stage           String    @default("COLD") // "COLD" | "CONTACTED" | "ENGAGED" | "ACTIVE" | "DORMANT"
  tags            String[]
  notes           String?
  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?
  ownerId         String?
  owner           Member?   @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  campaignId      String?
  campaign        Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  interactions    ContactInteraction[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([contactType, stage])
  @@index([nextFollowUpAt])
  @@index([ownerId])
}

model ContactInteraction {
  id         String          @id @default(cuid())
  contactId  String
  contact    OutreachContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  type       String          // "EMAIL" | "MEETING" | "CALL" | "NOTE" | "EVENT_ATTENDED"
  summary    String
  occurredAt DateTime        @default(now())
  memberId   String
  member     Member          @relation(fields: [memberId], references: [id])

  @@index([contactId])
}

model UtmLink {
  id           String   @id @default(cuid())
  code         String   @unique
  targetUrl    String
  submissionId String?
  submission   OutreachSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  platform     String?  // "instagram" | "linkedin" | "twitter" | "newsletter" | "website"
  clicks       Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([submissionId])
}

model PostMetric {
  id           String   @id @default(cuid())
  submissionId String
  submission   OutreachSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  platform     String   // "instagram" | "linkedin" | "twitter" | "website" | "newsletter"
  impressions  Int?
  likes        Int?
  comments     Int?
  shares       Int?
  clicks       Int?
  recordedAt   DateTime @default(now())
  recordedById String
  recordedBy   Member   @relation(fields: [recordedById], references: [id])

  @@index([submissionId])
  @@index([platform])
  @@index([recordedAt])
}

model NewsletterSubscriber {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  unsubscribeToken String   @unique
  confirmedAt     DateTime?
  unsubscribedAt  DateTime?
  source          String?   // "import" | "self-signup" | "manual"
  createdAt       DateTime  @default(now())
}

model NewsletterSend {
  id             String   @id @default(cuid())
  submissionId   String
  submission     OutreachSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  sentAt         DateTime @default(now())
  recipientCount Int      @default(0)
  opens          Int      @default(0)
  clicks         Int      @default(0)

  @@index([submissionId])
}

model ApprovalRecord {
  id           String   @id @default(cuid())
  submissionId String
  submission   OutreachSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  approverId   String
  approver     Member   @relation("SubmissionApprover", fields: [approverId], references: [id])
  approvedAt   DateTime @default(now())
  comment      String?

  @@unique([submissionId, approverId])
  @@index([submissionId])
}

model RecurringTemplate {
  id                    String   @id @default(cuid())
  templateSubmissionId  String
  templateSubmission    OutreachSubmission @relation(fields: [templateSubmissionId], references: [id], onDelete: Cascade)
  cronExpression        String
  defaultValues         Json?    // map of placeholder key → default value
  active                Boolean  @default(true)
  nextRunAt             DateTime
  lastRunAt             DateTime?
  ownerId               String
  owner                 Member   @relation("RecurringTemplateOwner", fields: [ownerId], references: [id])
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([templateSubmissionId])
  @@index([active, nextRunAt])
}
