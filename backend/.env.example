# Copy this file to .env and fill in real values.
# Never commit .env — it contains secrets.

# ── Environment ───────────────────────────────────────────────
# local dev:  NODE_ENV=development
# Oracle:     NODE_ENV=production
NODE_ENV=development

# ── Server ────────────────────────────────────────────────────
# local dev:  PORT=3001, BACKEND_URL=http://localhost:3001
# Oracle:     PORT=3001, BACKEND_URL=https://your-oracle-domain.duckdns.org
PORT=3001
BACKEND_URL=http://localhost:3001

# ── Frontend ──────────────────────────────────────────────────
# local dev:  FRONTEND_URL=http://localhost:3000
# Oracle:     FRONTEND_URL=https://purduesearch.github.io
FRONTEND_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────
# local dev:  use docker-compose postgres (matches docker-compose.yml defaults)
# Oracle:     use the server's local postgres connection string
DATABASE_URL=postgresql://clubpm:clubpm_dev@localhost:5432/club_pm

# ── Session ───────────────────────────────────────────────────
# Use a long random string in production: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-string

# ── Slack App Credentials ─────────────────────────────────────
# Bot token (xoxb-...) — OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Signing secret — Basic Information
SLACK_SIGNING_SECRET=your-signing-secret

# App-level token (xapp-...) — required for Socket Mode
# Create under Basic Information → App-Level Tokens with connections:write scope
SLACK_APP_TOKEN=xapp-your-app-token

# OAuth client credentials — Basic Information → App Credentials
SLACK_CLIENT_ID=your-client-id
SLACK_CLIENT_SECRET=your-client-secret

# ── Leadership channel ────────────────────────────────────────
# Members of this channel are granted admin (project creation) rights.
# Accepts a channel name ("leadership") or raw Slack channel ID ("C0123456789")
LEADERSHIP_CHANNEL_ID=leadership

# ── AI / Google ───────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash-lite
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# Base64-encoded service account JSON: base64 -w 0 service-account.json
GOOGLE_SERVICE_ACCOUNT_KEY=base64-encoded-service-account-json
AI_CACHE_TTL_SECONDS=300
